{
  "name": "double-entry-ledger",
  "version": "1.0.0",
  "description": "Production-grade Double-Entry Ledger System",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch --watch-path=src tsx src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "node --env-file=.env tsx src/db/seed.ts",
    "test": "node --env-file=.env.test vitest run",
    "test:watch": "node --env-file=.env.test vitest"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "7.2.0",
    "@types/cors": "2.8.17",
    "@types/morgan": "1.9.9",
    "@types/node": "22.10.7",
    "@types/pg": "8.11.10",
    "cors": "2.8.5",
    "drizzle-orm": "0.39.3",
    "express": "5.1.0",
    "helmet": "8.0.0",
    "morgan": "1.10.0",
    "pg": "8.13.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "5.0.1",
    "typescript": "5.7.3",
    "uuid": "11.0.5",
    "winston": "3.17.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "0.30.4",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "vitest": "3.0.5"
  }
}